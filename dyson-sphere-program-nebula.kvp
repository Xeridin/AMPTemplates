Meta.DisplayName=Dyson Sphere Program - Nebula
Meta.Description=Dyson Sphere Program headless multiplayer server using the Nebula mod
Meta.OS=Windows, Linux
Meta.AarchSupport=NotSupported
Meta.Arch=x86_64
Meta.Author=Xeridin / ChatGPT
Meta.URL=https://github.com/NebulaModTeam/nebula
Meta.DisplayImageSource=steam:1366540
Meta.EndpointURIFormat={ip}:{GenericModule.App.Ports.$ServerPort}
Meta.ConfigManifest=dyson-sphere-program-nebulaconfig.json
Meta.MetaConfigManifest=dyson-sphere-program-nebulametaconfig.json
Meta.ConfigRoot=dyson-sphere-program-nebula.kvp
Meta.MinAMPVersion=2.8.0.0
Meta.SpecificDockerImage=
Meta.DockerRequired=False
Meta.DockerBaseReadOnly=False
Meta.ContainerPolicy=SupportedOnWindows, SupportedOnLinux
Meta.ContainerPolicyReason=DSPGAME.exe is a Windows Unity executable. On Linux this template expects Wine and xvfb to be installed on the host.
Meta.ExtraSetupStepsURI=
Meta.Prerequisites=[]
Meta.ExtraContainerPackages=[]
Meta.ConfigReleaseState=NotSpecified
Meta.NoCommercialUsage=False
Meta.ConfigVersion=9
Meta.ReleaseNotes=Uses xvfb-run for Linux/Wine and tightens ready detection so startup failures are not treated as a running server.
Meta.BreakingReleaseNotes=
Meta.AppConfigId=53e76de5-839e-4b66-8409-5bf573024c8d
Meta.ImportableExtensions=[]
Meta.AppIsMultiIPAware=False
App.DisplayName=Dyson Sphere Program - Nebula
App.RootDir=./dyson-sphere-program-nebula/
App.BaseDirectory=./dyson-sphere-program-nebula/1366540/
App.SteamWorkshopDownloadLocation=
App.ExecutableWin=1366540\DSPGAME.exe
App.ExecutableLinux=/usr/bin/xvfb-run
App.WorkingDir=1366540
App.LinuxCommandLineArgs=-a -s "-screen 0 1024x768x24" /usr/bin/wine "./DSPGAME.exe"
App.WindowsCommandLineArgs=
App.CommandLineArgs={{$PlatformArgs}} -batchmode -nographics -nebula-server {{SaveLaunchArg}} {{CustomArgs}} {{$FormattedArgs}}
App.UseLinuxIOREDIR=False
App.AppSettings={}
App.EnvironmentVariables={"SteamAppId":"1366540","WINEPREFIX":"{{$FullRootDir}}.wine","WINEARCH":"win64","WINEDEBUG":"-all","WINEDLLOVERRIDES":"winhttp=n,b"}
App.CommandLineParameterFormat=-{0} {1}
App.CommandLineParameterDelimiter= 
App.ExitMethod=OS_CLOSE
App.ExitTimeout=10
App.ExitString=quit
App.ExitFile=app_exit.lck
App.HasWriteableConsole=True
App.HasReadableConsole=True
App.UDPLogger=False
App.SupportsLiveSettingsChanges=False
App.LiveSettingChangeCommandFormat=set {0} "{1}"
App.ForceIPBinding=False
App.SupportsIPv6=False
App.ApplicationIPBinding=0.0.0.0
App.Ports=@IncludeJson[dyson-sphere-program-nebulaports.json]
App.AdminPortRef=0
App.PrimaryApplicationPortRef=ServerPort
App.UniversalSleepApplicationUDPPortRef=0
App.UniversalSleepSteamQueryPortRef=0
App.MaxUsers=10
App.UseRandomAdminPassword=False
App.PersistRandomPassword=False
App.RemoteAdminPassword=
App.AdminMethod=STDIO
App.IgnoreSTDOUTAfterRCON=False
App.AdminLoginTransform=None
App.LoginTransformPrefix=
App.RCONConnectDelaySeconds=5
App.RCONConnectRetrySeconds=5
App.RCONHeartbeatMinutes=0
App.RCONHeartbeatCommand=ping
App.TelnetLoginFormat={0}
App.UpdateSources=@IncludeJson[dyson-sphere-program-nebulaupdates.json]
App.PreStartStages=[]
App.UserActions=[]
App.ForceUpdate=False
App.ForceUpdateReason=
App.Compatibility=None
App.SteamUpdateAnonymousLogin=False
App.SteamForceLoginPrompt=True
App.RapidStartup=False
App.SmartExcludeExemptions=["*.cfg","*.conf","*.config","*.ini","*.json","*.xml","*.properties","*.kvp","*.yml","*.yaml","*.toml","*.lua","*.sav","*.server","player.key"]
App.DumpFullChildProcessTree=True
App.MonitorChildProcessName=^.*(xvfb-run|wine|DSPGAME).*Nebula.*$
App.MonitorDirectChildOnly=False
App.SupportsUniversalSleep=False
App.WakeupMode=Any
App.ApplicationReadyMode=RegexMatch
Console.FilterMatchRegex=
Console.FilterMatchReplacement=
Console.ThrowawayMessageRegex=^((WARNING|ERROR): Shader.+|Could not find Wine Gecko.*|Mono path.*)$
Console.AppReadyRegex=.*(listening|server started|started server|host game started|Nebula API is ready).* 
Console.UserJoinRegex=.*(?<username>.+) joined.*
Console.UserLeaveRegex=.*(?<username>.+) left.*
Console.UserChatRegex=
Console.UpdateAvailableRegex=
Console.MetricsRegex=
Console.SuppressLogAtStart=False
Console.ActivateLogRegex=
Console.UserActions={}
Limits.SleepMode=False
Limits.SleepOnStart=False
Limits.SleepDelayMinutes=5
Limits.DozeDelay=2
Limits.SleepStartThresholdSeconds=25
Limits.AutoRetryCount=0
